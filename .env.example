# CursorHackathon.xyz — copy to `.env.local` and fill in real values.
# Never commit `.env.local` (it is gitignored).

# ------------------------------------------------------------------------------
# App
# ------------------------------------------------------------------------------
# Local dev: http://localhost:3000
# Production (Vercel): https://cursorhackathon.xyz
APP_URL=https://cursorhackathon.xyz

# ------------------------------------------------------------------------------
# Supabase (https://supabase.com/dashboard → Project Settings → API)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key
# Server only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ------------------------------------------------------------------------------
# Stripe (https://dashboard.stripe.com/apikeys)
# Create Products/Prices for Starter, Growth, Pro; paste Price IDs (price_...)
# Webhook: POST /api/stripe/webhook — use `stripe listen` locally for STRIPE_WEBHOOK_SECRET
# ------------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...

# ------------------------------------------------------------------------------
# OpenAI (https://platform.openai.com/api-keys)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# ------------------------------------------------------------------------------
# Firecrawl (https://www.firecrawl.dev/app/api-keys)
# ------------------------------------------------------------------------------
FIRECRAWL_API_KEY=fc-...

# ------------------------------------------------------------------------------
# Vapi (https://dashboard.vapi.ai → API Keys)
# Assistants are created with server.url = APP_URL/api/vapi/webhook automatically.
# VAPI_WEBHOOK_SECRET signs webhooks (x-vapi-signature); no dashboard Server URL setup.
# ------------------------------------------------------------------------------
VAPI_API_KEY=your-vapi-api-key
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret
# Optional: reuse an existing Vapi webhook credential id (skips POST /credential)
# VAPI_WEBHOOK_CREDENTIAL_ID=

# ------------------------------------------------------------------------------
# Twilio (https://console.twilio.com)
# Used to search/purchase numbers and import into Vapi
# ------------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# ------------------------------------------------------------------------------
# Resend (https://resend.com/api-keys)
# FROM must use a verified domain in production (testing: onboarding@resend.dev)
# ------------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Acme <onboarding@yourdomain.com>
